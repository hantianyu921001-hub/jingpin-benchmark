# 竞品Benchmark — 环境变量配置
# 复制此文件为 .env 并填入对应的 API Key

# ── 视觉识别模型（三选一即可） ───────────────────────────────────────
# 方案 A: 通用配置
# VISION_API_KEY=sk-your-key-here
# VISION_BASE_URL=https://api.deepseek.com
# VISION_MODEL=deepseek-v4-pro

# 方案 B: OpenAI GPT-4V（推荐，识别效果最好）
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# 方案 C: 通义千问 VL（国内可用，性价比高）
# DASHSCOPE_API_KEY=sk-your-dashscope-key

# 方案 D: DeepSeek V4（需要视觉代理或 bridge）
# DEEPSEEK_API_KEY=sk-your-deepseek-key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
